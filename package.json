{
  "name": "@terrestris/shogun-gis-client",
  "version": "11.1.2",
  "description": "This is the default GIS client used in the SHOGun project. Based on the react-geo-client template",
  "keywords": [
    "shogun",
    "react",
    "react-geo",
    "ol",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/terrestris/shogun-gis-client.git"
  },
  "license": "BSD-2-Clause",
  "author": "terrestris GmbH & Co. KG <info@terrestris.de>",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rspack --config rspack.prod.js build",
    "build:analyze": "npm run build -- --analyze",
    "build:babel": "BABEL_ENV=production babel src --out-dir dist --copy-files --no-copy-ignored --ignore 'src/**/*.spec.tsx' --ignore 'src/**/*.spec.js' --extensions '.ts,.tsx' --source-maps",
    "build:declaration": "tsc --emitDeclarationOnly",
    "build:dist": "npm run clean:dist && npm run build:babel && npm run build:declaration",
    "check": "npm run typecheck && npm run lint && npm run test",
    "clean:dist": "rimraf ./dist/* ./build/*",
    "lint": "eslint -c eslint.config.mjs src/",
    "lint:fix": "eslint -c eslint.config.mjs src/ --fix",
    "prepare": "husky",
    "start": "rspack serve --config rspack.dev.js",
    "test": "jest --maxWorkers=50% --coverage",
    "tsc": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "watch:buildto": "node watchBuild.js"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "@ngageoint/geopackage": "4.2.6",
    "@reduxjs/toolkit": "2.11.2",
    "@terrestris/base-util": "4.0.2",
    "@terrestris/mapfish-print-manager": "16.1.3",
    "@terrestris/ol-util": "21.3.2",
    "@terrestris/react-geo": "32.7.0",
    "@terrestris/react-util": "12.3.2",
    "@terrestris/shogun-e2e-tests": "1.0.8",
    "@terrestris/shogun-util": "10.11.1",
    "@types/color": "4.2.0",
    "@types/js-md5": "0.8.0",
    "@types/proj4": "2.19.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "antd": "5.29.3",
    "clsx": "2.1.1",
    "color": "5.0.3",
    "dayjs": "1.11.20",
    "dotenv": "17.4.2",
    "geostyler": "18.3.1",
    "geostyler-openlayers-parser": "5.4.1",
    "geostyler-style": "11.0.1",
    "i18next": "25.8.14",
    "i18next-browser-languagedetector": "8.2.1",
    "js-md5": "0.8.3",
    "keycloak-js": "26.2.4",
    "normalize.css": "8.0.1",
    "ol": "10.9.0",
    "ol-mapbox-style": "12.4.0",
    "proj4": "2.20.8",
    "react": "18.3.1",
    "react-cookie-consent": "10.0.1",
    "react-dom": "18.3.1",
    "react-i18next": "16.5.6",
    "react-markdown": "10.1.0",
    "react-redux": "9.2.0",
    "react-rnd": "10.5.3",
    "rehype-external-links": "3.0.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "shpjs": "6.2.0",
    "util": "0.12.5"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.28.6",
    "@casualbot/jest-sonar-reporter": "2.7.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "9.39.4",
    "@module-federation/enhanced": "0.24.1",
    "@playwright/test": "1.59.1",
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11",
    "@rspack/plugin-react-refresh": "1.6.2",
    "@stylistic/eslint-plugin": "5.10.0",
    "@swc/helpers": "0.5.23",
    "@terrestris/eslint-config-typescript": "10.0.0",
    "@terrestris/eslint-config-typescript-react": "6.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.7.0",
    "@types/shpjs": "3.4.7",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "babel-jest": "30.3.0",
    "babel-loader": "10.1.1",
    "buffer": "6.0.3",
    "chokidar": "5.0.0",
    "crypto-browserify": "3.12.1",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-refresh": "0.5.2",
    "fs-extra": "11.3.4",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "ignore-loader": "0.1.2",
    "jest": "30.3.0",
    "jest-canvas-mock": "2.5.2",
    "jest-environment-jsdom": "29.7.0",
    "less": "4.6.4",
    "less-loader": "12.3.2",
    "nwsapi": "2.2.23",
    "react-refresh": "0.18.0",
    "rimraf": "6.1.3",
    "streamx": "2.25.0",
    "style-loader": "4.0.0",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "webpack-merge": "6.0.1"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "publishConfig": {
    "access": "public"
  },
  "@casualbot/jest-sonar-reporter": {
    "suiteName": "jest tests",
    "outputDirectory": "coverage",
    "outputName": "jest-report.xml",
    "uniqueOutputName": "false",
    "classNameTemplate": "{classname}-{title}",
    "titleTemplate": "{classname}-{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": "true",
    "relativePaths": "true"
  },
  "overrides": {
    "geostyler-sld-parser": {
      "geostyler-style": "$geostyler-style"
    },
    "ol": "$ol",
    "proj4": "$proj4"
  }
}
